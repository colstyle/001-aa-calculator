{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AA计算器",
  "version": "0.1.0",
  "identifier": "com.aiprojects.aa-calculator",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "AA 计算器",
        "width": 480,
        "height": 760,
        "resizable": true,
        "center": true,
        "minWidth": 360,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
